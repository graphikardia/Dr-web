# =============================================================================
# Dr. Darshana Website - Environment Variables
# Add these in Vercel Dashboard → Settings → Environment Variables
# =============================================================================

# -------------------
# AI Chatbot (Required)
# -------------------
GROQ_API_KEY=           # Get free at https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile

# -------------------
# Web Search (Optional - for health questions)
# Uses Tavily (free 1000 searches/month)
# -------------------
SEARCH_API_KEY=         # Get free at https://tavily.com
# or use:
# TAVILY_API_KEY=

# -------------------
# Server Configuration
# -------------------
PING_MESSAGE=ping
ALLOWED_ORIGINS=        # Comma-separated: https://yoursite.vercel.app

# -------------------
# Contact Form (Optional)
# -------------------
VITE_GOOGLE_SHEET_URL=  # Google Apps Script web app URL